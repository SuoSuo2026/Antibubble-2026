@article{an_drop_2025,
	title = {Drop impact on a foam-coated liquid surface: formation of antibubbles},
	volume = {37},
	issn = {1070-6631, 1089-7666},
	shorttitle = {Drop impact on a foam-coated liquid surface},
	url = {https://pubs.aip.org/pof/article/37/2/023376/3336559/Drop-impact-on-a-foam-coated-liquid-surface},
	doi = {10.1063/5.0253926},
	abstract = {An antibubble is a rare fluid particle that a thin air film separates the inner and outer liquid phases. This unique structure makes antibubbles a promising candidate for droplet manipulation. The controlled formation of antibubbles has attracted increasing attention in recent decades. Among the various methods, drop impact on a foam-coated liquid surface has been identified as an efficient technique. Although this method has been widely used in previous research on antibubbles, the detailed dynamics of droplet collision on the foam layer has received limited attention. This paper demonstrates a systematic study of the dynamics of drop impact on a foam layer. Experimental results show that the contact position and the diameter ratio between the droplet and the bubbles that constitute the foam layer are key factors influencing the formation of antibubbles. Regime maps based on the experimental results are built to indicate the conditions under which antibubbles form. Additionally, a novel phenomenon is introduced, wherein antibubbles are formed when the droplet collides with the surface film of the foam bubbles.},
	language = {en},
	number = {2},
	urldate = {2026-03-11},
	journal = {Physics of Fluids},
	author = {An, Ji and Zhao, Guilin and Liu, Ziqi and Wang, Pengfei and Wang, Wei},
	month = feb,
	year = {2025},
	keywords = {/未读, /unread},
	pages = {023376},
	file = {An 等 - 2025 - Drop impact on a foam-coated liquid surface formation of antibubbles.pdf:D\:\\Program Files\\Zotero数据库\\storage\\TLVWX3TH\\An 等 - 2025 - Drop impact on a foam-coated liquid surface formation of antibubbles.pdf:application/pdf},
}

@article{wang_drop_2024,
	title = {Drop impact on a heated liquid bath: {Formation} of antibubbles},
	volume = {36},
	issn = {1070-6631, 1089-7666},
	shorttitle = {Drop impact on a heated liquid bath},
	url = {https://pubs.aip.org/pof/article/36/2/023313/3262762/Drop-impact-on-a-heated-liquid-bath-Formation-of},
	doi = {10.1063/5.0187791},
	abstract = {As a ubiquitous phenomenon, drop impact on a liquid bath has been widely studied. This paper demonstrates a systematical study on the collision between the volatile drops and a heated liquid bath. In the experiments, water, alcohol, and hydrogen fluoride ether (HFE-7100) were used to generate drops. The experimental results vary with the impact parameters and liquid properties. Despite the common phenomena, like bouncing and coalescence, antibubble was observed at an intermediate impact velocity with the HFE-7100 drops. A regime map is built based on the experimental results. A qualitative model is proposed to elucidate the stability of the air film separating the impinging droplet and the surrounding liquid during collision. This study should stimulate further investigation on the surfactant-free antibubbles and the control of antibubble lifetime.},
	language = {en},
	number = {2},

	annote = {The following values have no corresponding Zotero field:auth-address: Department of Mechanical Engineering, University College London, London, United Kingdom.edition: 2018/07/02accession-num: 29960423},
	file = {Naghavi和Czerski - 2018 - The acoustical signals produced by antibubble formation.pdf:D\:\\Program Files\\Zotero数据库\\storage\\H2IM83ZX\\Naghavi和Czerski - 2018 - The acoustical signals produced by antibubble formation.pdf:application/pdf},

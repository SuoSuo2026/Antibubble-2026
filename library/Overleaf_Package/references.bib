@article{kotopoulis_formulation_2022,
	title = {Formulation and characterisation of drug-loaded antibubbles for image-guided and ultrasound-triggered drug delivery},
	volume = {85},
	issn = {1873-2828 (Electronic) 1350-4177 (Print) 1350-4177 (Linking)},
	doi = {10.1016/j.ultsonch.2022.105986},
	abstract = {The aim of this study was to develop high load-capacity antibubbles that can be visualized using diagnostic ultrasound and the encapsulated drug can be released and delivered using clinically translatable ultrasound. The antibubbles were developed by optimising a silica nanoparticle stabilised double emulsion template. We produced an emulsion with a mean size diameter of 4.23 +/- 1.63 microm where 38.9 +/- 3.1\% of the droplets contained a one or more cores. Following conversion to antibubbles, the mean size decreased to 2.96 +/- 1.94 microm where 99\% of antibubbles were {\textless}10 microm. The antibubbles had a peak attenuation of 4.8 dB/cm at 3.0 MHz at a concentration of 200 x 10(3) particles/mL and showed distinct attenuation spikes at frequencies between 5.5 and 13.5 MHz. No increase in subharmonic response was observed for the antibubbles in contrast to SonoVue(R). High-speed imaging revealed that antibubbles can release their cores at MIs of 0.6. In vivo imaging indicated that the antibubbles have a long half-life of 68.49 s vs. 40.02 s for SonoVue(R). The antibubbles could be visualised using diagnostic ultrasound and could be disrupted at MIs of {\textgreater}/=0.6. The in vitro drug delivery results showed that antibubbles can significantly improve drug delivery (p {\textless} 0.0001) and deliver the drug within the antibubbles. In conclusion antibubbles are a viable concept for ultrasound guided drug delivery.},
	language = {en},
	journal = {Ultrason Sonochem},

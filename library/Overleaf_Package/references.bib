	annote = {Wu, ShengjiZuo, ZhigangStone, Howard ALiu, ShuhongengPhys Rev Lett. 2017 Aug 25;119(8):084501. doi: 10.1103/PhysRevLett.119.084501. Epub 2017 Aug 25.},

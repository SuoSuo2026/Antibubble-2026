@article{desai_ultrasound-triggered_2025,
	title = {Ultrasound-triggered drug release in vivo from antibubble-loaded macrophages},
	volume = {378},
	issn = {01683659},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S016836592400840X},
	doi = {10.1016/j.jconrel.2024.12.007},
	abstract = {Nanoparticles have proven to be attractive carriers in therapeutic drug delivery since they can encapsulate, protect and stabilize a plethora of different drugs, thereby improving therapeutic efficacy and reducing side effects. However, specific targeting of drug-loaded nanoparticles to the tissue of interest and a timely and spatially controlled release of drugs on demand still represent a challenge. Recently, gas-filled microparticles, socalled antibubbles, have been developed which can efficiently encapsulate liquid drug droplets. Here, we show that antibubbles are efficiently taken up by macrophages in vitro and are stably maintained for more than 48 h without compromising antibubble integrity and macrophage viability. We show that application of diagnostic ultrasound induces the disintegration of both antibubbles and carrier cells while not affecting non-loaded macrophages. Using 4-hydroxytamoxifen as a model drug, we show ultrasound-mediated drug release upon adoptive transfer of antibubble-loaded macrophages in mice. Together with the ability of macrophages to accumulate in inflamed tissues, antibubble-loaded macrophages represent an attractive tool for targeted delivery of drugs and its ultrasound-mediated spatial and temporal drug release, highlighting the therapeutic perspective of this strategy.},
	language = {en},
	urldate = {2026-03-12},
	journal = {Journal of Controlled Release},
	author = {Desai, Omkar and Köster, Mario and Kloos, Doreen and Lachmann, Nico and Hauser, Hansjörg and Poortinga, Albert and Wirth, Dagmar},
	month = feb,
	year = {2025},
	keywords = {/未读, /unread},
	pages = {365--376},
	file = {Desai 等 - 2025 - Ultrasound-triggered drug release in vivo from antibubble-loaded macrophages.pdf:D\:\\Program Files\\Zotero数据库\\storage\\JPFWHU4P\\Desai 等 - 2025 - Ultrasound-triggered drug release in vivo from antibubble-loaded macrophages.pdf:application/pdf},
}

@article{su_wetting-induced_2025,
	title = {Wetting-induced interfacial instability: a mechanism for droplet emission at air-liquid interfaces},
	volume = {11},
	issn = {2375-2548},
	shorttitle = {Wetting-induced interfacial instability},
	url = {https://www.science.org/doi/10.1126/sciadv.ads1065},
	doi = {10.1126/sciadv.ads1065},
	abstract = {High-throughput production of monodisperse microdroplets has revolutionized many fields, typically relying on shear-induced emulsification in intricate microfluidic channels to induce the Rayleigh-Plateau instability. This mechanism exhibits low robustness due to its high dependence on the physical properties and flow conditions of fluids. Here, we report a robust emulsification mechanism—wetting-induced interfacial instability—for droplet emission. We find that, when pendant microdroplets in the air contact with an immiscible wetting bulk phase, it triggers interfacial instability in the hanging droplets and then their rapid breakup into the bulk phase. This simplifies the monodisperse microdroplet production using a nozzle positioned above an air-liquid interface, requiring no complex microchannels. We demonstrate that this method exhibits highly scalable production and exceptional robustness against variations in physical properties and flow conditions of fluids, including highly viscous non-Newtonian fluid (56,600 millipascal-seconds). This mechanism provides a simpler alternative to the traditional Rayleigh-Plateau instability for emulsification, offering opportunities for industrial applications and insights into microscale interfacial science.
          , 
            Wetting-induced interfacial instability allows highly scalable and robust microfluidic emulsification for droplet emission.},
	language = {en},
	number = {12},
	urldate = {2026-03-13},
	journal = {Science Advances},
	author = {Su, Yao-Yao and Pan, Da-Wei and Zhang, Tao-Xian and Xie, Rui and Ju, Xiao-Jie and Liu, Zhuang and Deng, Nan-Nan and Wang, Wei and Chu, Liang-Yin},
	month = mar,
	year = {2025},
	keywords = {/已读, /unread},
	pages = {eads1065},
	file = {Su 等 - 2025 - Wetting-induced interfacial instability a mechanism for droplet emission at air-liquid interfaces.pdf:D\:\\Program Files\\Zotero数据库\\storage\\6PV3MLR2\\Su 等 - 2025 - Wetting-induced interfacial instability a mechanism for droplet emission at air-liquid interfaces.pdf:application/pdf},
}

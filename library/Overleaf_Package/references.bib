	annote = {The following values have no corresponding Zotero field:auth-address: Institut Lumiere Matiere, UMR5306 Universite Lyon 1-CNRS, Universite de Lyon 69622 Villeurbanne, France. anne-laure.biance@univ-lyon1.fr.edition: 2014/07/01accession-num: 24975425},
	file = {Piroird 等 - 2014 - Oil repartition in a foam film architecture.pdf:D\:\\Program Files\\Zotero数据库\\storage\\DZ8U4S8Q\\Piroird 等 - 2014 - Oil repartition in a foam film architecture.pdf:application/pdf},

	keywords = {/未读, /unread},
	pages = {128867},
	annote = {注意实验时SDS的质量分数不宜过高，否则会使反气泡产率反倒下降。质量分数以0.25-0.30\%为宜
},
	file = {Nivón-Ramírez 等 - 2022 - Critical micelle concentration of SDS through DPD simulations using COSMO-RS–based interaction param.pdf:D\:\\Program Files\\Zotero数据库\\storage\\XMQ8WQRC\\Nivón-Ramírez 等 - 2022 - Critical micelle concentration of SDS through DPD simulations using COSMO-RS–based interaction param.pdf:application/pdf},

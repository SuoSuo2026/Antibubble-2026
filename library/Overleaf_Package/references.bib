	annote = {Yanagisawa, NaoyaTani, MarieKurita, ReiengEnglandSoft Matter. 2021 Feb 21;17(7):1738-1745. doi: 10.1039/d0sm02153a. Epub 2021 Feb 17.},
	file = {Yanagisawa 等 - 2021 - Dynamics and mechanism of liquid film collapse in a foam.pdf:D\:\\Program Files\\Zotero数据库\\storage\\BWMXPHKW\\Yanagisawa 等 - 2021 - Dynamics and mechanism of liquid film collapse in a foam.pdf:application/pdf;Yanagisawa 等 - 2021 - Dynamics and mechanism of liquid film collapse in a foam.pdf:D\:\\Program Files\\Zotero数据库\\storage\\BHUPRG5T\\Yanagisawa 等 - 2021 - Dynamics and mechanism of liquid film collapse in a foam.pdf:application/pdf},

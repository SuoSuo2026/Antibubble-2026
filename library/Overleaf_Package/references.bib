@article{zhang_impact_2025,
	title = {Impact of viscous droplets on soap bubbles: coalescence suppresses bubble bursting in viscous regime},
	volume = {37},
	issn = {1070-6631, 1089-7666},
	shorttitle = {Impact of viscous droplets on soap bubbles},
	url = {https://pubs.aip.org/pof/article/37/12/122117/3374470/Impact-of-viscous-droplets-on-soap-bubbles},
	doi = {10.1063/5.0300616},
	abstract = {The impact of a viscous droplet on various surfaces is a fundamental physical process in nature and numerous technological fields. Despite the significant progress on understanding the impact dynamics of viscous droplets on solid surfaces and liquid films, the impact of viscous droplets on bubbles, especially the influence of droplet viscosity, is still poorly understood. Here, the impact dynamics of water-glycerol droplets with different viscosity on soap bubbles has been experimentally studied by high-speed camera. Similar to the water droplets impacting on soap bubbles, the droplet with higher viscosity rebounds from the soap bubble at low Weber number and passes through the large soap bubble at high Weber number. At high Weber number with small soap bubbles, the coalescence of the soap bubble with the highly viscous droplet mostly occurs, which is different from the “bubble bursting” for the impact of water droplets on soap bubbles reported previously. With the negligible viscous dissipation of droplets on soap bubbles, a general energy balance model is established to capture the transition of different impact behaviors for both low-viscosity and high-viscosity droplets impacting on soap bubbles. Increasing the viscosity of the droplet is found to suppress the bursting of small soap bubbles while promote the coalescence of the droplet with the soap bubble, and even the “passing” of the droplet. The dependence of the impact outcome on the viscosity of the droplet in the regime of small soap bubbles and high Weber number can be interpreted by the three-phase Taylor-Culick retraction.},
	language = {en},
	number = {12},
	urldate = {2026-03-03},
	journal = {Physics of Fluids},
	author = {Zhang, Xurui and Chang, Hao},
	month = dec,
	year = {2025},
	keywords = {/未读, /unread},
	pages = {122117},
	annote = {液滴砸向肥皂泡，有反弹，穿过，融合等regime
},
	file = {Zhang和Chang - 2025 - Impact of viscous droplets on soap bubbles coalescence suppresses bubble bursting in viscous regime.pdf:D\:\\Program Files\\Zotero数据库\\storage\\LLJNV9WL\\Zhang和Chang - 2025 - Impact of viscous droplets on soap bubbles coalescence suppresses bubble bursting in viscous regime.pdf:application/pdf},
}

@article{zhuang_school_2019,
	title = {School of mechanical engineering, shanghai jiao tong university, 200240, shanghai, china},
	volume = {16},
	issn = {1551-0018},
	url = {http://www.aimspress.com/article/10.3934/mbe.2019224},
	doi = {10.3934/mbe.2019224},
	abstract = {In the operation and maintenance of gas turbines, it is necessary to formulate a reasonable maintenance strategy according to the deformation and damage of the turbine to restore the performance of the gas turbine at a lower cost. In this regard, based on convolutional neural network (CNN), this paper develops a method to rapidly predict the impact of cascade aerodynamic performance according to geometric damage. In the study, a damaged blade dataset with a sample size of 670 is generated, in which the turbine blade damage is described by a two-dimensional matrix, and aerodynamic performance samples are obtained through CFD simulations. A CNN model for predicting the performance of damaged blades is trained and the model is subjected to sensitivity analysis. The effect of damage size and location on performance is summarized, and the results show that the damage on the suction side has the most significant effect on performance. The influence of the training sample size on the accuracy of CNN is discussed, and suggestions are given for the construction of CNN-based geometry-aerodynamic correlation models in the future.},

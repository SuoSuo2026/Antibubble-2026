	annote = {The following values have no corresponding Zotero field:auth-address: Department of Earth Science and Engineering, Imperial College London, SW7 2AZ, United Kingdom.edition: 2011/07/09accession-num: 21736320},
	file = {Neethling 等 - 2011 - Modeling oil droplets in plateau borders.pdf:D\:\\Program Files\\Zotero数据库\\storage\\9DI6NTXR\\Neethling 等 - 2011 - Modeling oil droplets in plateau borders.pdf:application/pdf},
